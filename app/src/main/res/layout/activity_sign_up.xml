<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.SignUpActivity"
    android:orientation="vertical"
    android:background="@drawable/background2">

    <ViewFlipper
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/viewFlipper">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:id="@+id/signUpScreen">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign up"
                android:textSize="40dp"
                android:textColor="#5D001E"
                android:gravity="center"
                android:layout_marginTop="50dp"
                android:id="@+id/tvSignUp"
                android:textStyle="bold"></TextView>

            <EditText
                android:layout_width="170dp"
                android:layout_height="wrap_content"
                android:hint="Enter username"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:id="@+id/etUserNameS"
                android:textColor="@color/black"></EditText>

            <EditText
                android:layout_width="170dp"
                android:layout_height="wrap_content"
                android:hint="Enter password"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:id="@+id/etPasswordS"
                android:inputType="textPassword"
                android:textColor="@color/black"></EditText>

            <EditText
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:hint="Password verification"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:id="@+id/etPasswordVerification"
                android:inputType="textPassword"
                android:textColor="@color/black"></EditText>

            <Button
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:text="Sign up"
                android:textSize="20dp"
                android:backgroundTint="#D6EF90A8"
                android:textColor="#5D001E"
                android:id="@+id/btnSignUp"
                android:layout_gravity="center"
                android:layout_marginTop="40dp"></Button>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Already have an account? Log in"
                android:textSize="20dp"
                android:textColor="#1C40FF"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:textStyle="italic"
                android:id="@+id/tvSwitchToLogIn"></TextView>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:id="@+id/logInScreen">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Log in"
                android:textSize="40dp"
                android:textColor="#5D001E"
                android:gravity="center"
                android:layout_marginTop="50dp"
                android:id="@+id/tvLogIn"
                android:textStyle="bold"></TextView>

            <EditText
                android:layout_width="170dp"
                android:layout_height="wrap_content"
                android:hint="Enter username"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:id="@+id/etUserNameL"
                android:textColor="@color/black"></EditText>

            <EditText
                android:layout_width="170dp"
                android:layout_height="wrap_content"
                android:hint="Enter password"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:id="@+id/etPasswordL"
                android:inputType="textPassword"
                android:textColor="@color/black"></EditText>

            <Button
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:text="Log in"
                android:textSize="20dp"
                android:backgroundTint="#D6EF90A8"
                android:textColor="#5D001E"
                android:id="@+id/btnLogIn"
                android:layout_gravity="center"
                android:layout_marginTop="40dp"></Button>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Don't have an account? Sign up"
                android:textSize="20dp"
                android:textColor="#1C40FF"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:textStyle="italic"
                android:id="@+id/tvSwitchToSignUp"></TextView>
        </LinearLayout>

    </ViewFlipper>
</LinearLayout>
